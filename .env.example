# Backend
ConnectionStrings__Postgres=Host=localhost;Port=5432;Database=document_verifier;Username=postgres;Password=postgres
Jwt__Issuer=DocumentVerifier
Jwt__Audience=DocumentVerifier.Web
Jwt__SigningKey=replace-with-at-least-32-random-characters
Jwt__ExpirationMinutes=120
Cors__FrontendOrigin=http://localhost:3000

# Blockchain
Blockchain__UseMock=false
Blockchain__RpcUrl=http://127.0.0.1:8545
Blockchain__ChainId=31337
Blockchain__ContractAddress=0x...
Blockchain__PrivateKey=set-via-local-secret-or-shell-env
Blockchain__NetworkName=hardhat-local

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:5000
